@page
@model LoginModel


<div class="wrapper">
    <div class="form-box signin">
        <h2>Sign In</h2>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly"></div>
                <div class="input-box">
                    <input asp-for="Input.UserName"  aria-required="true" />
                    <label asp-for="Input.UserName" ></label>
                    <span class="ico"> <i class="fa-solid fa-user"></i></span>
                </div>
                <div class ="input-box">
                    <span class="ico"><i class="fa-solid fa-lock"></i></span>
                <input asp-for="Input.Password" aria-required="true" id="password" />
                <img src="~/images/pass-hide.png" onclick="pass()" class="passicon" id="passicon">
                    <label asp-for="Input.Password" ></label>

                </div>
                <div>
                    <div class="remember-forgot">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="btnn">Sign in</button>
                </div>

                    <div class="signin-signup">
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                    </p>
                        <p>
                        Don't have an account?  <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                            Sign up
                            </a>
                        </p>
                </div>
            </form>
        <div class="media-options">
            <a asp-action="Signin" asp-controller="Account" asp-route-provider="Google">
                <i class="fa-brands fa-google"></i>
                <span>Sign in with Google</span>
            </a>
            <a asp-action="Signin" asp-controller="Account" asp-route-provider="Facebook">
                <i class="fa-brands fa-facebook"></i>
                <span>Sign in with Facebook</span>
            </a>
        </div>
    </div>
</div>
<script>
    var a;
    function pass() {
        if (a == 1) {
            document.getElementById("password").type = "password";
            document.getElementById("passicon").src = "/images/pass-hide.png";
            a = 0;
        }
        else {
            document.getElementById("password").type = "text";
            document.getElementById("passicon").src = "/images/pass-show.png";
            a = 1;
        }
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
