@page
@model DetailsModel

<style>
    /* Account Details start */
    .acc .dtl {
        display: flex;
        flex-wrap: wrap;
        max-width: 500px;
        align-items: center;
        margin: auto;
    }

        .acc .dtl form {
            border-radius: 10px;
            flex: 1 1 30rem;
            background-color: #162c43;
            box-shadow: var(--box-shodow);
            padding: 1.5rem;
        }

            .acc .dtl form h3 {
                font-size: 2rem;
                color: var(--other-color);
                text-align: center;
            }

            .acc .dtl form div {
                width: 100%;
                padding: 1rem;
                margin: 10px 0 0 0;
            }

        .acc .dtl .box p {
            color: var(--text-color);
            font-size: 20px;
            margin-bottom: 10px;
        }

    .btn {
        display: inline-block;
        padding: 17px 13px; /* Reduced padding for smaller buttons */
        background: var(--main-color);
        color: var(--text-color);
        font-size: 17px; /* Reduced font size for smaller buttons */
        font-weight: bold;
        transition: all 0.5s ease;
        border-radius: 10px;
        margin-right: 10px; /* Space between buttons */
    }

        .btn:last-child {
            margin-right: 0; /* Remove margin from the last button */
        }

    .acc .dtl .box .p {
        padding: 20px;
        height: 45px;
        width: 100%;
        color: var(--black);
        font-size: 18px;
        margin-left: 10px;
        background-color: white;
        border-radius: 5px;
        align-items: center;
        display: flex;
    }

    .acc .dtl a {
        margin-left: 5%;
    }

    .button-container {
        display: flex;
        justify-content: space-between;
        margin-top: 10px;
    }
    /* Account Details ends */
</style>

<section class="acc">
    <div class="dtl">
        <form action="" method="post">
            <h3>Account Details</h3>
            <div class="box">
                <p>Name :</p>
                <p class="p">@Model.User.UserName</p>
            </div>
            <div class="box">
                <p>Email :</p>
                <p class="p">@Model.User.Email</p>
            </div>
            <div class="box">
                <p>Phone Number :</p>
                <p class="p">@Model.User.PhoneNumber</p>
            </div>
            <div class="button-container">
                <a href="/Identity/Account/Manage/Dashboard" class="btn">Back to Account Management</a>
                <a href="/Identity/Account/Manage/UpdateAccount" class="btn">Update</a>
            </div>
        </form>
    </div>
</section>
